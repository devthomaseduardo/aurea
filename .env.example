# ── App ──
VITE_APP_URL=http://localhost:8080

# ── Firebase (produção — Auth + Firestore) ──
# Console: https://console.firebase.google.com
# 1. Crie o projeto
# 2. Authentication → Sign-in method → Google + GitHub + Email/Password
# 3. Firestore → Create database (production mode) + rules em firestore.rules
# 4. Project settings → Your apps → Web app → copiar config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Conectores (opcional, client) ──
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_GITHUB_OAUTH_CLIENT_ID=
