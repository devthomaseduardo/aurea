# ── Aurea API — variáveis de ambiente ─────────────────────────────
PORT=3001
NODE_ENV=development

# Firebase Admin SDK
# Opção A: service account JSON como string (recomendado para produção)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Opção B: arquivo de credenciais local (desenvolvimento)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

FIREBASE_PROJECT_ID=aurea-projeto

# CORS — domínios permitidos (separados por vírgula)
CORS_ORIGINS=http://localhost:5173,https://aurea.vercel.app

# Stripe (opcional — webhooks)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
